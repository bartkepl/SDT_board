<mah:MetroWindow x:Class="SDT_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:views="clr-namespace:SDT_App.Views"
        xmlns:vm="clr-namespace:SDT_App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SDT Board Companion"
        MinWidth="960" MinHeight="680"
        Height="780" Width="1100"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Closing="OnWindowClosing">

    <DockPanel LastChildFill="True">

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MahApps.Brushes.ThemeForeground}"
                Opacity="0.15"
                Height="0"/>
        <Grid DockPanel.Dock="Bottom" Height="26"
              Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Ellipse Grid.Column="0" Width="10" Height="10" Margin="8,0,4,0" VerticalAlignment="Center"
                     Fill="{Binding IsConnected, Converter={StaticResource BoolToColor},
                                    ConverterParameter='44BB66|EE4444'}"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center"
                       Margin="0,0,12,0" Width="320" TextTrimming="CharacterEllipsis"/>
            <Separator Grid.Column="2" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,4"/>
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="8,0"
                       FontFamily="Consolas" FontSize="11" Opacity="0.7"
                       Text="{Binding LastCommandDisplay}" TextTrimming="CharacterEllipsis"/>
            <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="8,0"
                       Text="{Binding SensorTypeDisplay, StringFormat='Sensor: {0}'}"/>
        </Grid>

        <!-- Log panel -->
        <GroupBox DockPanel.Dock="Bottom" Header="Log" Height="150" Margin="4,0,4,2">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Clear"
                        Command="{Binding ClearLogCommand}"
                        VerticalAlignment="Top" Margin="4,4,4,0"
                        Width="56" Height="24"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"/>
                <ListBox x:Name="LogList"
                         ItemsSource="{Binding LogEntries}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="2,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding FormattedTime}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#888888" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Message}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{Binding Level, Converter={StaticResource LogLevelToColor}}"
                                           TextWrapping="NoWrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </GroupBox>

        <!-- Main tab control -->
        <mah:MetroTabControl Margin="4,4,4,0" TabStripPlacement="Top">

            <!-- Connection -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Connection" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Connection" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <views:ConnectionView DataContext="{Binding ConnectionVm}"/>
            </TabItem>

            <!-- Sensor -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Thermometer" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Sensor" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <views:SensorView DataContext="{Binding SensorVm}"/>
            </TabItem>

            <!-- TMP117 -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ThermometerAlert" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="TMP117" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <views:Tmp117View DataContext="{Binding Tmp117Vm}"/>
            </TabItem>

            <!-- Display -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Monitor" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Display" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DisplayView DataContext="{Binding DisplayVm}"/>
            </TabItem>

            <!-- System -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="CogOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="System" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <views:SystemView DataContext="{Binding SystemVm}"/>
            </TabItem>

            <!-- Measurements -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ChartLine" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Measurements" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <views:MeasurementsView DataContext="{Binding MeasurementsVm}"/>
            </TabItem>

            <!-- DFU Programmer -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Download" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="DFU Programmer" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DfuView DataContext="{Binding DfuVm}"/>
            </TabItem>

            <!-- Console -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Console" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <views:ConsoleView DataContext="{Binding ConsoleVm}"/>
            </TabItem>

        </mah:MetroTabControl>
    </DockPanel>
</mah:MetroWindow>
