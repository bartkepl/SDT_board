<UserControl x:Class="SDT_App.Views.MeasurementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:vm="clr-namespace:SDT_App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:MeasurementsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <StackPanel Grid.Column="0">

            <!-- Polling Config -->
            <GroupBox Header="Polling Configuration" Margin="0,0,0,8">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Interval [s]:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="2" Text="{Binding IntervalText}"
                             IsEnabled="{Binding IsPolling, Converter={StaticResource BoolInverse}}"/>
                </Grid>
            </GroupBox>

            <!-- Controls -->
            <GroupBox Header="Controls" Margin="0,0,0,8">
                <StackPanel Margin="8">
                    <Button Command="{Binding StartPollingCommand}"
                            IsEnabled="{Binding IsPolling, Converter={StaticResource BoolInverse}}"
                            Margin="0,0,0,6"
                            Style="{StaticResource MahApps.Styles.Button.Square.Accent}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Play" Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Start Polling" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding StopPollingCommand}"
                            IsEnabled="{Binding IsPolling}"
                            Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Stop" Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Stop Polling" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ClearDataCommand}" Content="Clear Data"/>
                </StackPanel>
            </GroupBox>

            <!-- Live Readings -->
            <GroupBox Header="Live Readings" Margin="0,0,0,8">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Temp:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LiveTemperature}"
                               Foreground="#E06633" FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Humidity:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LiveHumidity}"
                               Foreground="#4488CC" FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Samples:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SampleCount}"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>

            <!-- CSV Export -->
            <GroupBox Header="CSV Export">
                <StackPanel Margin="8">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding CsvPath}"
                                 FontSize="10" mah:TextBoxHelper.Watermark="CSV file path..."/>
                        <Button Grid.Column="2" Content="..."
                                Command="{Binding BrowseCsvCommand}" Width="28"/>
                    </Grid>
                    <Button Command="{Binding StartCsvCommand}"
                            Content="Start CSV Logging" Margin="0,0,0,4"
                            Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                            IsEnabled="{Binding CsvLogging, Converter={StaticResource BoolInverse}}"/>
                    <Button Command="{Binding StopCsvCmdCommand}"
                            Content="Stop CSV Logging" Margin="0,0,0,6"
                            IsEnabled="{Binding CsvLogging}"/>
                    <TextBlock Text="{Binding CsvStatusText}" FontSize="11" Opacity="0.8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CsvLogging}" Value="True">
                                        <Setter Property="Foreground" Value="#44BB66"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </GroupBox>

        </StackPanel>

        <!-- Right: Chart -->
        <GroupBox Grid.Column="2" Header="Live Measurements Chart">
            <oxy:PlotView Model="{Binding PlotModel}" Background="Transparent"/>
        </GroupBox>

    </Grid>
</UserControl>
