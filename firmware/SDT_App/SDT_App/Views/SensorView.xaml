<UserControl x:Class="SDT_App.Views.SensorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:vm="clr-namespace:SDT_App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SensorViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Readings + Actions -->
            <StackPanel Grid.Column="0">
                <GroupBox Header="Live Readings" Margin="0,0,0,8">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Temperature:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TemperatureText}"
                                   Style="{StaticResource ValueText}" VerticalAlignment="Center"/>
                        <Button Grid.Row="0" Grid.Column="3" Content="Read"
                                Command="{Binding ReadTemperatureCommand}"
                                IsEnabled="{Binding IsConnected}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Humidity:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HumidityText}"
                                   Style="{StaticResource ValueText}" VerticalAlignment="Center"/>
                        <Button Grid.Row="2" Grid.Column="3" Content="Read"
                                Command="{Binding ReadHumidityCommand}"
                                IsEnabled="{Binding IsConnected}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Sensor Type:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SensorTypeText}"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                        <Button Grid.Row="4" Grid.Column="3" Content="Query"
                                Command="{Binding QuerySensorTypeCommand}"
                                IsEnabled="{Binding IsConnected}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Sensor ID:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SensorIdText}"
                                   FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Row="6" Grid.Column="3" Content="Query"
                                Command="{Binding QuerySensorIdCommand}"
                                IsEnabled="{Binding IsConnected}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Actions">
                    <StackPanel Margin="8" Orientation="Horizontal">
                        <Button Content="Heater ON (SHT45)"
                                Command="{Binding HeaterCommand}"
                                IsEnabled="{Binding IsConnected}"
                                Margin="0,0,8,0"/>
                        <Button Content="Soft Reset"
                                Command="{Binding SoftResetCommand}"
                                IsEnabled="{Binding IsConnected}"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- Right: Configuration -->
            <GroupBox Grid.Column="2" Header="Configuration">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Read Period -->
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                               Text="Read Period [50-60000 ms]"/>
                    <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding ReadPeriodText}"
                             IsEnabled="{Binding IsConnected}"/>
                    <Button Grid.Row="0" Grid.Column="4" Content="Set"
                            Command="{Binding SetReadPeriodCommand}"
                            IsEnabled="{Binding IsConnected}"/>
                    <Button Grid.Row="0" Grid.Column="6" Content="Get"
                            Command="{Binding GetReadPeriodCommand}"
                            IsEnabled="{Binding IsConnected}"/>

                    <!-- Average -->
                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                               Text="Average (SHT45: 1-255 / TMP117: 1,8,32,64)"/>
                    <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding AverageText}"
                             IsEnabled="{Binding IsConnected}"/>
                    <Button Grid.Row="2" Grid.Column="4" Content="Set"
                            Command="{Binding SetAverageCommand}"
                            IsEnabled="{Binding IsConnected}"/>
                    <Button Grid.Row="2" Grid.Column="6" Content="Get"
                            Command="{Binding GetAverageCommand}"
                            IsEnabled="{Binding IsConnected}"/>

                    <!-- Precision -->
                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                               Text="Precision (SHT45 only)"/>
                    <ComboBox Grid.Row="4" Grid.Column="2"
                              ItemsSource="{Binding PrecisionOptions}"
                              SelectedItem="{Binding SelectedPrecision}"
                              IsEnabled="{Binding IsConnected}"/>
                    <Button Grid.Row="4" Grid.Column="4" Content="Set"
                            Command="{Binding SetPrecisionCommand}"
                            IsEnabled="{Binding IsConnected}"/>
                    <Button Grid.Row="4" Grid.Column="6" Content="Get"
                            Command="{Binding GetPrecisionCommand}"
                            IsEnabled="{Binding IsConnected}"/>
                </Grid>
            </GroupBox>

        </Grid>
    </ScrollViewer>
</UserControl>
